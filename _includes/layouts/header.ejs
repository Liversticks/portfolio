<header>
    <div>
        <h1 id="siteTitle"><a href="/"><%= siteTitle %></a></h1>
    </div>
    <div id="toggle">
        <nav role="navigation">
            <input type="checkbox"/>
            <img class="menu-icon" src="/static/images/bars.svg" alt="Hamburger menu icon" />
            <ul>
                <% menuLinks.forEach(function(link) { %>
                    <li class="nav-item">
                        <a href="<%= link.link %>" class="nav-link"><%= link.name %></a>
                    </li>
                <% }) %>
            </ul>
        </nav>
    </div>
</header>